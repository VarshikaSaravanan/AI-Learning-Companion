# =============================================================================
# AI Learning Companion - Environment Configuration
# =============================================================================
# Copy this file and adjust values for your local machine.
# All inference runs locally via Ollama — no cloud API keys required.
# =============================================================================

# Ollama server URL (default local installation)
OLLAMA_BASE_URL=http://localhost:11434

# Local LLM for text generation — DOWNLOAD FIRST: ollama pull gemma4
OLLAMA_LLM_MODEL=gemma4

# Embedding model for vector search — DOWNLOAD: ollama pull nomic-embed-text
# Required for RAG semantic search (small ~300MB download)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Directory paths (relative to project root)
UPLOAD_DIR=uploads
VECTORSTORE_DIR=vectorstore
DATA_DIR=data

# Text chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
TOP_K_RESULTS=4

# LLM generation settings
LLM_TEMPERATURE=0.3
